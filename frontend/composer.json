{
    "name": "grupo6/educational-frontend",
    "type": "project",
    "description": "Frontend educativo - Laravel 11 Modular + Octane",
    "keywords": ["laravel", "octane", "modular", "educational", "devops"],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "11.0|^12.0",
        "laravel/octane": "^2.0",
        "laravel/sanctum": "^4.0",
        "spiral/roadrunner-grpc": "^3.0",
        "google/protobuf": "^3.25|^4.0",
        "nwidart/laravel-modules": "^11.0",
        "spatie/laravel-health": "^1.0",
        "promphp/prometheus_client_php": "^2.0",
        "vlucas/phpdotenv": "^5.6",
        "predis/predis": "^2.2"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^1.11",
        "laravel/pint": "^1.15",
        "mockery/mockery": "^1.6",
        "fakerphp/faker": "^1.23",
        "spatie/laravel-ray": "^1.31"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "app/Modules/"
        },
        "files": [
            "app/Modules/Auth/helpers.php",
            "app/Modules/Academic/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "test": "vendor/bin/pest --parallel",
        "test:coverage": "vendor/bin/pest --parallel --coverage --min=70",
        "lint": "vendor/bin/pint --test",
        "lint:fix": "vendor/bin/pint",
        "stan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "health": "php artisan health:check"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
