# ==============================================================================
# Educational Backend - Environment Variables
# Copy to .env and adjust values for your environment
# ==============================================================================

# --- Application ---
ENVIRONMENT=development
DEBUG=true

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# gRPC Server
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# --- Database ---
# postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://edu_user:edu_pass@localhost:5432/educational
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# --- Redis ---
REDIS_URL=redis://localhost:***REMOVED***

# --- JWT Authentication ---
# Generate with: openssl genrsa -out jwt_private.pem 2048 && openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=["http://localhost:8080", "http://localhost:3000"]

# --- Observability ---
OTEL_SERVICE_NAME=educational-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_PORT=9090

# --- Email (optional) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@educational.local

# --- External Services ---
# GCP / Cloud (for Sprint 2+)
GCP_PROJECT_ID=
GKE_CLUSTER_NAME=
GKE_REGION=